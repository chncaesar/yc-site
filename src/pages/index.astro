---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const interviews = (await getCollection('interview')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const healthPosts = (await getCollection('health')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredInterviews = interviews.slice(0, 3);
const otherFeatured = healthPosts.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "禹畅",
				"description": "长期专访青年中医的独立写作者，兼写中医育儿健康科普",
				"url": "https://xn--doyx8g.com",
				"knowsAbout": ["中医", "青年中医", "中医育儿", "健康科普"]
			}
		</script>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-inner">
				<p class="hero-eyebrow">明医志 · 长期写作 · 记录好中医</p>
				<h1>找到那个能<br />治好你的人</h1>
			<p class="hero-sub">
				禹畅，长期专访青年中医的独立写作者。<br />
				行业里最会吆喝的人，往往不是最会治病的人。<br />
				我只写有疗效的人。
			</p>
				<a href="/articles" class="btn">读文章</a>
				<a href="/about" class="btn btn-outline">了解作者</a>
			</div>
		</section>

		<!-- 精选文章 -->
		<section class="featured">
			<div class="section-inner">
				<h2 class="section-title">近期专访</h2>
				<ul class="cards">
					{featuredInterviews.map((post) => (
						<li class="card">
							<a href={`/${post.collection}/${post.id}/`}>
								<div class="card-body">
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									<span class="card-read">阅读全文 →</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			</div>
		</section>

		<!-- 精选科普 & 动态 -->
		<section class="featured-other">
			<div class="section-inner">
				<h2 class="section-title">健康科普</h2>
				<ul class="cards">
					{otherFeatured.map((post) => (
						<li class="card">
							<a href={`/${post.collection}/${post.id}/`}>
								<div class="card-body">
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									<span class="card-read">阅读全文 →</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			</div>
		</section>

		<!-- 内容领域 -->
		<section class="topics" id="topics">
			<div class="section-inner">
				<h2 class="section-title">主要内容领域</h2>
				<dl class="topic-list">
					<div class="topic-item">
						<dt><a href="/interview/">青年中医专访</a></dt>
						<dd>全国青年中医的临床特色、医德与师承故事</dd>
					</div>
					<div class="topic-item">
						<dt><a href="/health/">中医育儿与健康科普</a></dt>
						<dd>基于权威指南与临床实践的家庭健康决策参考</dd>
					</div>
					<div class="topic-item">
						<dt><a href="/events/">行业会议与现场报道</a></dt>
						<dd>中医行业活动记录、会议观察与一手报道</dd>
					</div>
				</dl>
			</div>
		</section>

		<!-- 关于作者 -->
		<section class="about-strip">
			<div class="section-inner about-inner">
				<div class="about-text">
					<p class="about-label">关于作者</p>
					<p class="about-bio">
						有底线的原党报版面负责人，莆田系医院当道时曾拒绝其冠名；中医考证中，采访了全国几十位好中医；多项国家专利，曾作为重要贡献者获300万科技补助，高交会&国际工博会奖项；会带娃爬树，玩飞拉达，种菜。
					</p>
					<a href="/about" class="btn">了解禹畅 →</a>
				</div>
			</div>
		</section>

		<!-- 更多文章入口 -->
		<section class="more-link">
			<div class="section-inner">
				<a href="/articles" class="btn">浏览全部文章 →</a>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq" id="faq">
			<div class="section-inner">
				<h2 class="section-title">常见问题</h2>
				<dl class="faq-list">
					<div class="faq-item">
						<dt>Q：这个网站主要写什么？</dt>
						<dd>A：专访有疗效、缺传播渠道的青年中医，兼写中医育儿健康科普。</dd>
					</div>
					<div class="faq-item">
						<dt>Q：作者是谁？</dt>
						<dd>A：禹畅，原党报版面负责人，长期采访全国青年中医。</dd>
					</div>
					<div class="faq-item">
						<dt>Q：内容是否持续更新？</dt>
						<dd>A：是，长期更新。</dd>
					</div>
				</dl>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
/* ── Hero ── */
.hero {
	background: var(--green-dark);
	color: var(--paper);
	padding: 5em 1.5em 4em;
}

.hero-inner {
	max-width: 680px;
	margin: 0 auto;
}

.hero-eyebrow {
	font-size: 0.85em;
	letter-spacing: 0.15em;
	color: var(--gold);
	text-transform: uppercase;
	margin-bottom: 0.8em;
}

.hero h1 {
	font-family: var(--font-serif);
	font-size: clamp(2.4em, 6vw, 3.6em);
	color: var(--paper);
	line-height: 1.2;
	margin: 0 0 0.6em;
}

.hero-sub {
	font-size: 1.05em;
	color: rgba(247,243,236,0.75);
	line-height: 1.8;
	margin-bottom: 2em;
}

.hero .btn {
	margin-right: 1em;
	margin-bottom: 0.8em;
}

.hero .btn-outline {
	border-color: rgba(201,168,76,0.6);
	color: var(--gold-light);
}

.hero .btn-outline:hover {
	background: var(--gold);
	color: var(--green-dark);
	border-color: var(--gold);
}

/* ── Section base ── */
.section-inner {
	max-width: var(--max-wide);
	margin: 0 auto;
	padding: 0 1.5em;
}

.section-title {
	font-family: var(--font-serif);
	font-size: 1.4em;
	color: var(--green-dark);
	margin: 0 0 1.5em;
	padding-bottom: 0.5em;
	border-bottom: 2px solid var(--gold);
	display: inline-block;
}

/* ── 精选文章卡片 ── */
.featured {
	padding: 4em 0 3em;
	background: var(--paper);
}

.cards {
	list-style: none;
	margin: 0;
	padding: 0;
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1.5em;
}

.card {
	background: var(--white);
	border-radius: var(--radius-lg);
	box-shadow: var(--shadow-sm);
	transition: box-shadow 0.2s, transform 0.2s;
	overflow: hidden;
}

.card:hover {
	box-shadow: var(--shadow-md);
	transform: translateY(-3px);
}

.card a {
	display: block;
	text-decoration: none;
	height: 100%;
}

.card-body {
	padding: 1.5em;
	display: flex;
	flex-direction: column;
	height: 100%;
}

.card-title {
	font-family: var(--font-serif);
	font-size: 1em;
	color: var(--green-dark);
	line-height: 1.5;
	margin: 0 0 0.8em;
	font-weight: 700;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.card-desc {
	font-size: 0.85em;
	color: rgb(var(--ink-light));
	line-height: 1.6;
	flex: 1;
	margin: 0 0 1em;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.card-read {
	font-size: 0.85em;
	color: var(--gold);
	font-weight: 500;
}

/* ── 关于作者条 ── */
.about-strip {
	background: var(--paper-dark);
	padding: 3.5em 0;
}

.about-inner {
	max-width: 720px;
}

.about-label {
	font-size: 0.8em;
	letter-spacing: 0.15em;
	color: var(--gold);
	text-transform: uppercase;
	margin-bottom: 0.8em;
}

.about-bio {
	font-size: 1.05em;
	line-height: 1.9;
	color: rgb(var(--ink));
	margin-bottom: 1.5em;
}

/* ── 更多文章入口 ── */
.more-link {
	padding: 0 0 4em;
	background: var(--paper);
	text-align: center;
}

.more-link .section-inner {
	max-width: 720px;
}

/* ── 响应式 ── */
@media (max-width: 900px) {
	.cards {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (max-width: 600px) {
	.hero {
		padding: 3.5em 1em 3em;
	}

	.cards {
		grid-template-columns: 1fr;
	}

	.section-inner {
		padding: 0 1em;
	}
}

/* ── 内容领域 ── */
.topics {
	padding: 3.5em 0;
	background: var(--paper);
}

.topic-list {
	margin: 0;
	padding: 0;
	list-style: none;
}

.topic-item {
	margin-bottom: 1.5em;
}

.topic-item:last-child {
	margin-bottom: 0;
}

.topic-item dt {
	font-family: var(--font-serif);
	font-size: 1.1em;
	font-weight: 700;
	color: var(--green-dark);
	margin-bottom: 0.3em;
}

.topic-item dt a {
	color: inherit;
	text-decoration: none;
}

.topic-item dt a:hover {
	color: var(--gold);
}

.topic-item dd {
	margin: 0;
	font-size: 0.95em;
	color: rgb(var(--ink-mid));
	line-height: 1.7;
}

/* ── FAQ ── */
.faq {
	padding: 3.5em 0 4em;
	background: var(--paper-dark);
}

.faq-list {
	margin: 0;
	padding: 0;
	list-style: none;
}

.faq-item {
	margin-bottom: 1.8em;
}

.faq-item:last-child {
	margin-bottom: 0;
}

.faq-item dt {
	font-family: var(--font-serif);
	font-size: 1em;
	font-weight: 700;
	color: var(--green-dark);
	margin-bottom: 0.3em;
}

.faq-item dd {
	margin: 0;
	font-size: 0.95em;
	color: rgb(var(--ink-mid));
	line-height: 1.7;
}

/* ── 精选科普 & 动态 ── */
.featured-other {
	padding: 0 0 4em;
	background: var(--paper);
}
</style>
