---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/articles">文章</HeaderLink>
			<HeaderLink href="/interview">专访</HeaderLink>
			<HeaderLink href="/health">科普</HeaderLink>
			<HeaderLink href="/events">动态</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<a href="/about#contact" class="nav-cta">联系</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--green-dark);
		box-shadow: 0 2px 12px rgba(0,0,0,0.18);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-wide);
		margin: 0 auto;
		padding: 0 1.5em;
		height: 60px;
	}

	.site-title {
		font-family: var(--font-serif);
		font-size: 1.15em;
		font-weight: 700;
		color: var(--gold);
		text-decoration: none;
		letter-spacing: 0.05em;
		white-space: nowrap;
	}

	.site-title:hover {
		color: var(--gold-light);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.2em;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links :global(a) {
		color: rgba(247,243,236,0.85);
		text-decoration: none;
		font-size: 0.95em;
		padding: 0.4em 0.8em;
		border-radius: 4px;
		transition: color 0.2s, background 0.2s;
		border-bottom: none;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--gold);
		background: rgba(201,168,76,0.1);
	}

	.nav-cta {
		margin-left: 0.5em;
		background: var(--gold) !important;
		color: var(--green-dark) !important;
		font-weight: 700;
		border-radius: 100px !important;
		padding: 0.35em 1.1em !important;
	}

	.nav-cta:hover {
		background: var(--gold-light) !important;
	}

	@media (max-width: 480px) {
		.site-title {
			font-size: 1em;
		}

		.nav-links :global(a) {
			padding: 0.4em 0.5em;
			font-size: 0.9em;
		}
	}
</style>
